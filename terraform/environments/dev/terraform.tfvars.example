# terraform.tfvars.example — Example variable values for the dev environment.
#
# Copy this file to terraform.tfvars and fill in your real values.
# terraform.tfvars is gitignored — never commit it.
#
# Sensitive values (VPC ID, subnet ID, operator CIDR) must never be committed.
# Add them here as infrastructure is introduced, then keep this file gitignored.

aws_region     = "eu-west-2"
aws_profile    = "dev"
aws_account_id = "YOUR_DEV_ACCOUNT_ID"  # prevents accidental apply to wrong account
project        = "aws-vpn"
environment    = "dev"
