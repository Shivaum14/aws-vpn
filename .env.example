# .env.example — Local overrides for make targets.
#
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
#   cp .env.example .env

# Path to the EC2 SSH private key used by Ansible.
# Must match the key_name set in terraform.tfvars.
SSH_KEY_PATH=/path/to/your/key.pem
